$C = "../Common.ui";
$Sounds = "../Sounds.ui";

@IconAdd = "../Icons/perm_add.png";
@IconDelete = "../Icons/perm_delete.png";
@IconMore = "../Icons/perm_more_horizontal.png";
@IconChevronLeft = "../Icons/perm_chevron_left.png";

@IconButton = Button {
  @Icon = "";
  @Anchor = Anchor();
  @Sounds = $Sounds.@ButtonsLight;

  Style: (
    Default: (Background: (TexturePath: @Icon, Color: #ffffff(0.9))),
    Hovered: (Background: (TexturePath: @Icon, Color: #ffffff)),
    Pressed: (Background: (TexturePath: @Icon, Color: #ffffff(0.75))),
    Sounds: @Sounds
  );
  Anchor: (...@Anchor, Width: 28, Height: 28);
};

$C.@PageOverlay {
  LayoutMode: Middle;

  $C.@DecoratedContainer {
    @CloseButton = true;
    Anchor: (Width: 900, Height: 720);

    #Title {
      $C.@Title #TitleLabel {
        @Text = "Player Permissions";
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Full: 16);

      Label #SubtitleLabel {
        Anchor: (Bottom: 12, Horizontal: 6);
        Style: (...$C.@DefaultLabelStyle, Wrap: true, FontSize: 14, TextColor: #9aa9b4);
        Text: "Manage a player's groups and direct permissions.";
      }

      Group #PlayerHeaderRow {
        LayoutMode: Left;
        Anchor: (Bottom: 12, Height: 30);

        Label {
          Text: "Player";
          Anchor: (Width: 80);
          Style: (...$C.@DefaultLabelStyle, VerticalAlignment: Center);
        }

        Label #PlayerNameLabel {
          Anchor: (Width: 220);
          Style: (...$C.@DefaultLabelStyle, VerticalAlignment: Center, TextColor: #c7d6df);
          Text: "";
        }

        Label #PlayerUuidLabel {
          Anchor: (Width: 320);
          Style: (...$C.@DefaultLabelStyle, VerticalAlignment: Center, FontSize: 11, TextColor: #8fa3b5);
          Text: "";
        }
      }

      Group #Columns {
        LayoutMode: Left;
        Anchor: (Height: 560);

        Group #GroupPanel {
          LayoutMode: Top;
          Anchor: (Width: 420, Height: 560);
          Background: (TexturePath: "../Common/ContainerPanelPatch.png", Border: 4);
          Padding: (Full: 12);

          Label #GroupTitle {
            Text: "Groups";
            Anchor: (Bottom: 4);
            Style: (...$C.@DefaultLabelStyle, RenderBold: true, FontSize: 15, TextColor: #c7d6df);
          }

          Label #GroupHint {
            Anchor: (Bottom: 10);
            Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #8fa3b5, Wrap: true);
            Text: "Assign this player to groups.";
          }

          Group #GroupAddRow {
            LayoutMode: Left;
            Anchor: (Bottom: 8, Height: 35);

            Label {
              Text: "Add";
              Anchor: (Width: 60);
              Style: (...$C.@DefaultLabelStyle, VerticalAlignment: Center);
            }

            Group #GroupInput {
              FlexWeight: 1;
              $C.@DropdownBox #Input { Anchor: (Width: 220, Height: $C.@DropdownBoxHeight); }
            }

            @IconButton #AddGroupButton { @Icon = @IconAdd; @Anchor = (Left: 8, Top: 3); }
          }

          Label #GroupEmptyLabel {
            Anchor: (Bottom: 6);
            Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #8fa3b5);
            Text: "No groups assigned.";
          }

          Label #GroupOverflowLabel {
            Anchor: (Bottom: 6);
            Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #8fa3b5);
            Text: "Showing the first 8 groups.";
          }

          Group #GroupListScroller {
            LayoutMode: TopScrolling;
            ScrollbarStyle: $C.@DefaultScrollbarStyle;
            Anchor: (Height: 300);

            Group #GroupRow0 {
              LayoutMode: Left;
              Anchor: (Bottom: 6, Height: 30);
              Label #GroupLabel0 { Anchor: (Width: 300); Style: (...$C.@DefaultLabelStyle, VerticalAlignment: Center); Text: "group"; }
              @IconButton #GroupRemove0 { @Icon = @IconDelete; }
            }

            Group #GroupRow1 {
              LayoutMode: Left;
              Anchor: (Bottom: 6, Height: 30);
              Label #GroupLabel1 { Anchor: (Width: 300); Style: (...$C.@DefaultLabelStyle, VerticalAlignment: Center); Text: "group"; }
              @IconButton #GroupRemove1 { @Icon = @IconDelete; }
            }

            Group #GroupRow2 {
              LayoutMode: Left;
              Anchor: (Bottom: 6, Height: 30);
              Label #GroupLabel2 { Anchor: (Width: 300); Style: (...$C.@DefaultLabelStyle, VerticalAlignment: Center); Text: "group"; }
              @IconButton #GroupRemove2 { @Icon = @IconDelete; }
            }

            Group #GroupRow3 {
              LayoutMode: Left;
              Anchor: (Bottom: 6, Height: 30);
              Label #GroupLabel3 { Anchor: (Width: 300); Style: (...$C.@DefaultLabelStyle, VerticalAlignment: Center); Text: "group"; }
              @IconButton #GroupRemove3 { @Icon = @IconDelete; }
            }

            Group #GroupRow4 {
              LayoutMode: Left;
              Anchor: (Bottom: 6, Height: 30);
              Label #GroupLabel4 { Anchor: (Width: 300); Style: (...$C.@DefaultLabelStyle, VerticalAlignment: Center); Text: "group"; }
              @IconButton #GroupRemove4 { @Icon = @IconDelete; }
            }

            Group #GroupRow5 {
              LayoutMode: Left;
              Anchor: (Bottom: 6, Height: 30);
              Label #GroupLabel5 { Anchor: (Width: 300); Style: (...$C.@DefaultLabelStyle, VerticalAlignment: Center); Text: "group"; }
              @IconButton #GroupRemove5 { @Icon = @IconDelete; }
            }

            Group #GroupRow6 {
              LayoutMode: Left;
              Anchor: (Bottom: 6, Height: 30);
              Label #GroupLabel6 { Anchor: (Width: 300); Style: (...$C.@DefaultLabelStyle, VerticalAlignment: Center); Text: "group"; }
              @IconButton #GroupRemove6 { @Icon = @IconDelete; }
            }

            Group #GroupRow7 {
              LayoutMode: Left;
              Anchor: (Bottom: 6, Height: 30);
              Label #GroupLabel7 { Anchor: (Width: 300); Style: (...$C.@DefaultLabelStyle, VerticalAlignment: Center); Text: "group"; }
              @IconButton #GroupRemove7 { @Icon = @IconDelete; }
            }
          }
        }

        Group #PermissionPanel {
          LayoutMode: Top;
          Anchor: (Left: 12, Width: 420, Height: 560);
          Background: (TexturePath: "../Common/ContainerPanelPatch.png", Border: 4);
          Padding: (Full: 12);

          Label #PermissionTitle {
            Text: "Direct Permissions";
            Anchor: (Bottom: 4);
            Style: (...$C.@DefaultLabelStyle, RenderBold: true, FontSize: 15, TextColor: #c7d6df);
          }

          Label #PermissionHint {
            Anchor: (Bottom: 10);
            Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #8fa3b5, Wrap: true);
            Text: "Grant or revoke permissions specific to this player.";
          }

          Group #PermissionAddRow {
            LayoutMode: Left;
            Anchor: (Bottom: 8, Height: 34);

            Label {
              Text: "Add";
              Anchor: (Width: 60);
              Style: (...$C.@DefaultLabelStyle, VerticalAlignment: Center);
            }

            $C.@TextField #PermissionInput {
              Anchor: (Width: 220);
              PlaceholderText: "permission.node";
            }

            @IconButton #AddPermissionButton { @Icon = @IconAdd; @Anchor = (Left: 8, Top: 3); }
            @IconButton #PermissionBrowseButton { @Icon = @IconMore; @Anchor = (Left: 6, Top: 3); }
          }

          Label #PermissionEmptyLabel {
            Anchor: (Bottom: 6);
            Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #8fa3b5);
            Text: "No direct permissions.";
          }

          Label #PermissionOverflowLabel {
            Anchor: (Bottom: 6);
            Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #8fa3b5);
            Text: "Showing the first 8 permissions.";
          }

          Group #PermissionListScroller {
            LayoutMode: TopScrolling;
            ScrollbarStyle: $C.@DefaultScrollbarStyle;
            Anchor: (Height: 300);

            Group #PermissionRow0 {
              LayoutMode: Left;
              Anchor: (Bottom: 6, Height: 30);
              Label #PermissionLabel0 { Anchor: (Width: 300); Style: (...$C.@DefaultLabelStyle, VerticalAlignment: Center); Text: "permission.node"; }
              @IconButton #PermissionRemove0 { @Icon = @IconDelete; }
            }

            Group #PermissionRow1 {
              LayoutMode: Left;
              Anchor: (Bottom: 6, Height: 30);
              Label #PermissionLabel1 { Anchor: (Width: 300); Style: (...$C.@DefaultLabelStyle, VerticalAlignment: Center); Text: "permission.node"; }
              @IconButton #PermissionRemove1 { @Icon = @IconDelete; }
            }

            Group #PermissionRow2 {
              LayoutMode: Left;
              Anchor: (Bottom: 6, Height: 30);
              Label #PermissionLabel2 { Anchor: (Width: 300); Style: (...$C.@DefaultLabelStyle, VerticalAlignment: Center); Text: "permission.node"; }
              @IconButton #PermissionRemove2 { @Icon = @IconDelete; }
            }

            Group #PermissionRow3 {
              LayoutMode: Left;
              Anchor: (Bottom: 6, Height: 30);
              Label #PermissionLabel3 { Anchor: (Width: 300); Style: (...$C.@DefaultLabelStyle, VerticalAlignment: Center); Text: "permission.node"; }
              @IconButton #PermissionRemove3 { @Icon = @IconDelete; }
            }

            Group #PermissionRow4 {
              LayoutMode: Left;
              Anchor: (Bottom: 6, Height: 30);
              Label #PermissionLabel4 { Anchor: (Width: 300); Style: (...$C.@DefaultLabelStyle, VerticalAlignment: Center); Text: "permission.node"; }
              @IconButton #PermissionRemove4 { @Icon = @IconDelete; }
            }

            Group #PermissionRow5 {
              LayoutMode: Left;
              Anchor: (Bottom: 6, Height: 30);
              Label #PermissionLabel5 { Anchor: (Width: 300); Style: (...$C.@DefaultLabelStyle, VerticalAlignment: Center); Text: "permission.node"; }
              @IconButton #PermissionRemove5 { @Icon = @IconDelete; }
            }

            Group #PermissionRow6 {
              LayoutMode: Left;
              Anchor: (Bottom: 6, Height: 30);
              Label #PermissionLabel6 { Anchor: (Width: 300); Style: (...$C.@DefaultLabelStyle, VerticalAlignment: Center); Text: "permission.node"; }
              @IconButton #PermissionRemove6 { @Icon = @IconDelete; }
            }

            Group #PermissionRow7 {
              LayoutMode: Left;
              Anchor: (Bottom: 6, Height: 30);
              Label #PermissionLabel7 { Anchor: (Width: 300); Style: (...$C.@DefaultLabelStyle, VerticalAlignment: Center); Text: "permission.node"; }
              @IconButton #PermissionRemove7 { @Icon = @IconDelete; }
            }
          }
        }
      }

      Group #FooterRow {
        LayoutMode: Left;
        Anchor: (Top: 6, Height: 30);

        @IconButton #BackButton { @Icon = @IconChevronLeft; }

        Label {
          Text: "Back";
          Anchor: (Left: 6);
          Style: (...$C.@DefaultLabelStyle, VerticalAlignment: Center);
        }
      }
    }
  }
}

$C.@BackButton {}
