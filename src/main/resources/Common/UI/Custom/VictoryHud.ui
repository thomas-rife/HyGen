Group #VictoryHudRoot {
  Anchor: (Top: 0, Bottom: 0, Left: 0, Right: 0);
  LayoutMode: Middle;

  Label #VictoryLabel {
    Text: "VICTORY";
    Anchor: (Width: 720, Height: 120);
    Style: (
      FontSize: 86,
      TextColor: #ffffff,
      RenderBold: true,
      HorizontalAlignment: Center,
      VerticalAlignment: Center
    );
  }
}
