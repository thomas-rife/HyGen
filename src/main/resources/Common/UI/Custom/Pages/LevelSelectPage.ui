    Group #TutorialCard {
      Anchor: (Left: 176, Top: 370, Width: 854, Height: 70);
      Background: (Color: #1a1a1a(0.82));
      OutlineColor: #f4e9d5;
      OutlineSize: 2;

      Label #TutorialTitle {
        Text: "How to Play";
        Anchor: (Top: 10, Left: 20, Width: 150, Height: 22);
        Style: (FontSize: 18, TextColor: #f4e9d5, RenderBold: true, HorizontalAlignment: Start, VerticalAlignment: Center);
      }

      Label #TutorialBody {
        Text: "WASD to move    1, 2, 3 to swap characters    Right Click for abilities";
        Anchor: (Top: 38, Left: 20, Right: 20, Height: 22);
