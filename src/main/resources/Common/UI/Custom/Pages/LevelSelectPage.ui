Group #LevelSelectRoot {
  Anchor: (Top: 0, Bottom: 0, Left: 0, Right: 0);
  LayoutMode: Middle;

  Button #BackBtn {
    Anchor: (Top: 40, Right: 40, Width: 140, Height: 50);
    OutlineColor: #f4e9d5;
    OutlineSize: 2;
    Style: (
      Default: (Background: (Color: #1a1a1a(0.8))),
      Hovered: (Background: (Color: #c5b496)),
      Pressed: (Background: (Color: #e6d5b8))
    );
    Label {
      Text: "Back";
      Style: (FontSize: 22, TextColor: #f4e9d5, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
    }
  }

  Group #MapFrame {
    Anchor: (Width: 1188, Height: 454);

    Group #RouteLine01 { Anchor: (Left: 260, Top: 222, Width: 106, Height: 4); Background: (Color: #0f0e0b(0.4)); }
    Group #RouteLine02 { Anchor: (Left: 450, Top: 222, Width: 106, Height: 4); Background: (Color: #0f0e0b(0.2)); }
    Group #RouteLine03 { Anchor: (Left: 640, Top: 222, Width: 52, Height: 4); Background: (Color: #0f0e0b(0.2)); }
    Group #BranchStub { Anchor: (Left: 688, Top: 143, Width: 4, Height: 164); Background: (Color: #0f0e0b(0.2)); }
    Group #RouteLine04 { Anchor: (Left: 696, Top: 143, Width: 50, Height: 4); Background: (Color: #0f0e0b(0.2)); }
    Group #RouteLine05 { Anchor: (Left: 696, Top: 299, Width: 50, Height: 4); Background: (Color: #0f0e0b(0.2)); }
    Group #RouteLine06 { Anchor: (Left: 830, Top: 143, Width: 62, Height: 4); Background: (Color: #0f0e0b(0.2)); }
    Group #RouteLine07 { Anchor: (Left: 830, Top: 299, Width: 62, Height: 4); Background: (Color: #0f0e0b(0.2)); }
    Group #RouteLine08 { Anchor: (Left: 888, Top: 143, Width: 4, Height: 164); Background: (Color: #0f0e0b(0.2)); }
    Group #RouteLine09 { Anchor: (Left: 896, Top: 222, Width: 50, Height: 4); Background: (Color: #0f0e0b(0.2)); }

    // Node 01
    Group #LevelNode01C { Anchor: (Left: 176, Top: 181, Width: 84, Height: 84); Visible: false; OutlineColor: #0f0e0b; OutlineSize: 2; Button #LevelNode01BtnC { Anchor: (Top: 0, Bottom: 0, Left: 0, Right: 0); Style: ( Default: (Background: (Color: #f4e9d5)), Hovered: (Background: (Color: #c5b496)), Pressed: (Background: (Color: #e6d5b8)) ); Label { Text: "1"; Style: (FontSize: 30, TextColor: #1a1a1a, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); } } }
